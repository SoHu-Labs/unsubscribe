# Email Digest — environment variables
# Copy to .env and fill in values

# Gmail API (OAuth token file — same path for unsubscribe + digest).
# Scopes: gmail.readonly (required). Include gmail.send if topics use output.also_email_to (digest self-email via API).
GOOGLE_OAUTH_TOKEN=~/path/to/oauth_token.json

# LLM API keys
DEEPSEEK_API_KEY=sk-...
# Optional future: Minimax / opencode (`cheap` alias) — not wired yet; see docs/IMPLEMENTATION_PLAN_EMAIL_SUMMARIES.md
# OPENCODE_API_KEY=sk-...

# LM Studio local fallback (OpenAI-compatible API). Use the model ids from LM Studio’s Local Server
# dropdown (they may differ from folder names on disk). Default presets (see local-chat src/llm.py):
#   LM_STUDIO_MODEL        → Qwen3.5 4B MLX      (~/.lmstudio/models/mlx-community/Qwen3.5-4B-MLX-4bit)
#   LM_STUDIO_MODEL_SMART  → Qwen3-4B-Instruct   (~/.lmstudio/models/lmstudio-community/Qwen3-4B-Instruct-2507-MLX-4bit)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=replace-with-lm-studio-model-id-for-qwen3.5-4b
LM_STUDIO_MODEL_SMART=replace-with-lm-studio-model-id-for-qwen3-4b-instruct

# Digest SQLite (optional — default is <repo>/cache/digest.sqlite)
# DIGEST_CACHE_DB=/path/to/digest.sqlite
