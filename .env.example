# Email Digest — environment variables
# Copy to .env and fill in values

# Gmail API (OAuth token file — ported from billing-glugglejug)
GOOGLE_OAUTH_TOKEN=~/path/to/oauth_token.json

# LLM API keys
DEEPSEEK_API_KEY=sk-...
# Minimax M2.5 via opencode proxy
OPENCODE_API_KEY=sk-...

# LM Studio local fallback (OpenAI-compatible API)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# Gmail SMTP for email delivery (optional — same as billing-glugglejug)
GMAIL_SMTP_USER=your-email@gmail.com
GMAIL_SMTP_APP_PASSWORD=your-app-password
