# Email Digest — environment variables
# Copy to .env and fill in values

# Gmail API (OAuth token file — same path for unsubscribe + digest).
# Scopes: gmail.readonly (required). Include gmail.send if topics use output.also_email_to (digest self-email via API).
GOOGLE_OAUTH_TOKEN=~/path/to/oauth_token.json

# LLM API keys
DEEPSEEK_API_KEY=sk-...
# Optional future: Minimax / opencode (`cheap` alias) — not wired yet; see docs/IMPLEMENTATION_PLAN_EMAIL_SUMMARIES.md
# OPENCODE_API_KEY=sk-...

# LM Studio local fallback is handled via direct MLX (mlx_lm), matching local-chat's
# MLX_MODEL_VARIANTS dict. No env vars needed — models are loaded from:
#   ~/.lmstudio/models/
#
# Defaults:
#   local        → Qwen3.5-2B-MLX-4bit  (alias "2b")
#   local_smart  → Qwen3.5-4B-MLX-4bit  (alias "4b")
# See src/email_digest/llm.py for full MODEL_VARIANTS.

# Digest SQLite (optional — default is <repo>/cache/digest.sqlite)
# DIGEST_CACHE_DB=/path/to/digest.sqlite
